# MongoDB connection string (set this to your MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/roomhy?retryWrites=true&w=majority

# Optional import secret for local->Mongo import endpoint
IMPORT_SECRET=some-strong-secret

# JWT secret used by auth middleware
JWT_SECRET=change_this_secret

# Razorpay Configuration - REQUIRED for payment processing
# Get your keys from https://dashboard.razorpay.com/app/keys
# Test Key: rzp_test_XXXXXXXXXXXXXXXX
# Live Key: rzp_live_XXXXXXXXXXXXXXXX (only use in production)
RAZORPAY_KEY_ID=rzp_test_your_test_key_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Mailjet Configuration - REQUIRED for emails (credentials, OTP, reminders, notifications)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM_EMAIL=no-reply@yourdomain.com
MAILJET_FROM_NAME=RoomHy

# Optional: superadmin fallback email for platform-level notifications
SUPERADMIN_EMAIL=roomhy01@gmail.com
