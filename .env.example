# MongoDB connection string (set this to your MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/roomhy?retryWrites=true&w=majority

# Optional import secret for local->Mongo import endpoint
IMPORT_SECRET=some-strong-secret

# JWT secret used by auth middleware
JWT_SECRET=change_this_secret

# Razorpay Configuration - REQUIRED for payment processing
# Get your keys from https://dashboard.razorpay.com/app/keys
# Test Key: rzp_test_XXXXXXXXXXXXXXXX
# Live Key: rzp_live_XXXXXXXXXXXXXXXX (only use in production)
RAZORPAY_KEY_ID=rzp_test_your_test_key_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Mailjet Configuration - REQUIRED for emails (credentials, OTP, reminders, notifications)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM_EMAIL=no-reply@yourdomain.com
MAILJET_FROM_NAME=RoomHy

# WhatsApp Cloud API Configuration (Meta)
# Add a permanent token with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token
# Your shared value: 968428819695214
WHATSAPP_PHONE_NUMBER_ID=968428819695214
# Optional: API version and default country code for phone normalization
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_VERIFY_TOKEN=replace_with_secure_webhook_verify_token
WHATSAPP_BOT_ENABLED=true
WHATSAPP_BOT_BRAND_NAME=RoomHy
WHATSAPP_BOT_SUPPORT_PHONE=+91XXXXXXXXXX
WHATSAPP_BOT_SUPPORT_EMAIL=support@roomhy.com
# Optional reference only
WHATSAPP_BUSINESS_ACCOUNT_ID=1463189491991857

# Optional: superadmin fallback email for platform-level notifications
SUPERADMIN_EMAIL=roomhy01@gmail.com

# Production domain configuration
# API host used by backend-to-backend callbacks and notifications
API_URL=https://api.roomhy.com

# Public website
WEBSITE_URL=https://roomhy.com

# Admin / superadmin / employee panel
ADMIN_URL=https://admin.roomhy.com

# Owner / tenant app panel
APP_URL=https://app.roomhy.com

# Digital check-in public entry
DIGITAL_CHECKIN_URL=https://admin.roomhy.com
BACKEND_URL=https://api.roomhy.com

# Cashfree DigiLocker
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2023-08-01

# Zoho Sign owner agreement flow
ZOHO_SIGN_ACCESS_TOKEN=your_zoho_sign_access_token
ZOHO_SIGN_CREATE_URL=https://sign.zoho.in/api/v1/requests
ZOHO_SIGN_TEMPLATE_ID=your_owner_agreement_template_id
ZOHO_SIGN_CALLBACK_URL=https://api.roomhy.com/api/checkin/owner/agreement/callback

# Backward-compatible legacy aliases still read by some files
FRONTEND_URL=https://admin.roomhy.com
APP_BASE_URL=https://app.roomhy.com

# CORS allowlist for browser clients
CORS_ORIGINS=https://roomhy.com,https://www.roomhy.com,https://admin.roomhy.com,https://app.roomhy.com,https://api.roomhy.com
